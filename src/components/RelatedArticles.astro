---
interface LessonRef {
  slug: string;
  data: {
    title: string;
    module: string;
    order: number;
    description: string;
    duration: string;
    level: string;
  };
}

interface Props {
  currentModule: string;
  currentOrder: number;
  allLessons: LessonRef[];
  max?: number;
}

const { currentModule, currentOrder, allLessons, max = 3 } = Astro.props;

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}

const moduleNames: Record<string, string> = {
  'm1-basics': '入门篇',
  'm2-thinking': '思维篇',
  'm3-practice': '实战篇',
  'm4-advanced': '进阶篇',
  'm5-compare': '工具对比',
  'm6-sidebiz': '副业指南',
};

// Pick related articles: same module (excluding current), then other modules
const sameModule = allLessons
  .filter(l => l.data.module === currentModule && l.data.order !== currentOrder)
  .sort(() => Math.random() - 0.5)
  .slice(0, 2);

const otherModules = allLessons
  .filter(l => l.data.module !== currentModule)
  .sort(() => Math.random() - 0.5)
  .slice(0, max);

const related = [...sameModule, ...otherModules].slice(0, max);
---

{related.length > 0 && (
  <div class="related-articles">
    <h3 class="related-title">推荐阅读</h3>
    <div class="related-grid">
      {related.map(article => (
        <a class="related-card" href={lessonUrl(article.slug)}>
          <span class="related-module">{moduleNames[article.data.module] || article.data.module}</span>
          <span class="related-card-title">{article.data.title}</span>
          <span class="related-desc">{article.data.description}</span>
          <span class="related-meta">{article.data.duration} · {article.data.level}</span>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .related-articles {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid var(--gray-200, #e5e5e5);
  }

  .related-title {
    font-family: var(--serif, serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--ink, #1a1a1a);
    margin: 0 0 20px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px;
    border: 1px solid var(--gray-200, #e5e5e5);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .related-card:hover {
    border-color: var(--accent, #b44a3e);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .related-module {
    font-family: var(--sans, sans-serif);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent, #b44a3e);
    letter-spacing: 0.03em;
  }

  .related-card-title {
    font-family: var(--serif, serif);
    font-size: 15px;
    font-weight: 700;
    color: var(--ink, #1a1a1a);
    line-height: 1.45;
  }

  .related-desc {
    font-size: 13px;
    color: var(--gray-500, #666);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-meta {
    font-size: 12px;
    color: var(--gray-400, #999);
    margin-top: auto;
  }

  @media (max-width: 600px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
