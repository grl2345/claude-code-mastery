---
import '../styles/terminal.css';

interface Props {
  title?: string;
}

const { title = 'claude-code — zsh' } = Astro.props;
---

<div class="hero-terminal">
  <div class="terminal-bar">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
    <span class="terminal-title">{title}</span>
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>
