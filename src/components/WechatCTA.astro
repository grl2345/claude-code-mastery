---
interface Props {
  variant?: 'inline' | 'banner';
}
const { variant = 'inline' } = Astro.props;
---

<div class={`wechat-cta ${variant}`}>
  <div class="wechat-cta-inner">
    <div class="wechat-cta-text">
      <h4>{variant === 'banner' ? '关注公众号，获取更多 AI 编程干货' : '觉得有用？关注公众号获取更多'}</h4>
      <p>每周更新 Claude Code 实战技巧、工具对比、行业动态。回复「模板」获取 CLAUDE.md 模板合集。</p>
    </div>
    <div class="wechat-cta-action">
      <div class="wechat-qr-placeholder">
        <div class="wechat-qr-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <span class="wechat-qr-text">微信扫码关注</span>
        <span class="wechat-qr-name">CC精通之路</span>
      </div>
    </div>
  </div>
</div>

<style>
  .wechat-cta {
    border-radius: 12px;
    overflow: hidden;
  }
  .wechat-cta.inline {
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    border: 1.5px solid #bbf7d0;
    margin: 40px 0;
  }
  .wechat-cta.banner {
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2520 100%);
    color: #fff;
    margin: 0;
  }
  .wechat-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 28px 32px;
  }
  .wechat-cta-text h4 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .inline .wechat-cta-text h4 {
    color: #166534;
  }
  .wechat-cta-text p {
    font-size: 13px;
    line-height: 1.6;
  }
  .inline .wechat-cta-text p {
    color: #4b5563;
  }
  .banner .wechat-cta-text p {
    color: rgba(255,255,255,.6);
  }
  .wechat-qr-placeholder {
    width: 120px;
    height: 120px;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-align: center;
  }
  .inline .wechat-qr-placeholder {
    background: #fff;
    border: 1.5px dashed #86efac;
  }
  .banner .wechat-qr-placeholder {
    background: rgba(255,255,255,.1);
    border: 1.5px dashed rgba(255,255,255,.3);
  }
  .wechat-qr-icon {
    opacity: .5;
  }
  .banner .wechat-qr-icon {
    color: #fff;
  }
  .wechat-qr-text {
    font-size: 11px;
    opacity: .6;
  }
  .wechat-qr-name {
    font-size: 13px;
    font-weight: 600;
  }
  .inline .wechat-qr-name {
    color: #166534;
  }

  @media (max-width: 640px) {
    .wechat-cta-inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 24px 20px;
    }
    .wechat-qr-placeholder {
      margin: 0 auto;
    }
  }
</style>
