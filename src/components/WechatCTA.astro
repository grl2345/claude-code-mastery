---
interface Props {
  variant?: 'inline' | 'banner';
}
const { variant = 'inline' } = Astro.props;
---

<div class={`wechat-cta ${variant}`}>
  <div class="wechat-cta-inner">
    <div class="wechat-cta-text">
      <h4>{variant === 'banner' ? '关注公众号，获取更多 AI 编程干货' : '觉得有用？关注公众号获取更多'}</h4>
      <p>每周更新 Claude Code 实战技巧、工具对比、行业动态。</p>
    </div>
    <div class="wechat-cta-action">
      <div class="wechat-qr-placeholder">
        <img src="/wechat-qr.jpg" alt="小高聊AI微信公众号二维码" width="90" height="90" />
        <span class="wechat-qr-text">微信扫码关注</span>
        <span class="wechat-qr-name">小高聊AI</span>
      </div>
    </div>
  </div>
</div>

<style>
  .wechat-cta {
    border-radius: 12px;
    overflow: hidden;
  }
  .wechat-cta.inline {
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    border: 1.5px solid #bbf7d0;
    margin: 40px 0;
  }
  .wechat-cta.banner {
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2520 100%);
    color: #fff;
    margin: 0;
  }
  .wechat-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 28px 32px;
  }
  .wechat-cta-text h4 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .inline .wechat-cta-text h4 {
    color: #166534;
  }
  .wechat-cta-text p {
    font-size: 13px;
    line-height: 1.6;
  }
  .inline .wechat-cta-text p {
    color: #4b5563;
  }
  .banner .wechat-cta-text p {
    color: rgba(255,255,255,.6);
  }
  .wechat-qr-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }
  .wechat-qr-placeholder img {
    border-radius: 8px;
    display: block;
  }
  .wechat-qr-text {
    font-size: 11px;
    opacity: .6;
  }
  .wechat-qr-name {
    font-size: 13px;
    font-weight: 600;
  }
  .inline .wechat-qr-name {
    color: #166534;
  }

  @media (max-width: 640px) {
    .wechat-cta-inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 24px 20px;
    }
    .wechat-qr-placeholder {
      margin: 0 auto;
    }
  }
</style>
