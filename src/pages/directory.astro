---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);

const modules = [
  { id: 'm1-basics',   name: '入门篇',   color: '#2d8a56', prefix: 'm1' },
  { id: 'm2-thinking', name: '思维篇',   color: '#c44b2b', prefix: 'm2' },
  { id: 'm3-practice', name: '实战篇',   color: '#2b6cc4', prefix: 'm3' },
  { id: 'm4-advanced', name: '进阶篇',   color: '#7c3aed', prefix: 'm4' },
  { id: 'm5-compare',  name: '工具对比', color: '#c44b2b', prefix: 'm5' },
  { id: 'm6-sidebiz',  name: '副业指南', color: '#2d8a56', prefix: 'm6' },
];

// Group lessons by module, then by group, sorted by order
const moduleData = modules.map(mod => {
  const lessons = allLessons
    .filter(l => l.data.module === mod.id)
    .sort((a, b) => a.data.order - b.data.order);
  const groups = new Map<string, typeof lessons>();
  for (const lesson of lessons) {
    const group = lesson.data.group || '目录';
    if (!groups.has(group)) groups.set(group, []);
    groups.get(group)!.push(lesson);
  }
  return { ...mod, lessons, groups };
});

const totalCount = allLessons.length;

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}
---

<BaseLayout
  title="全部文章目录 - Claude Code 精通之路"
  description="Claude Code 精通之路全站文章目录，按模块分类浏览所有教程，快速定位你需要的内容。"
>
  <div class="dir-page">
    <!-- Header -->
    <div class="dir-header">
      <div class="dir-header-inner">
        <a class="dir-back" href="/">&larr; 返回首页</a>
        <h1>全部文章目录</h1>
        <p class="dir-subtitle">共 {totalCount} 篇文章，涵盖从入门到进阶的完整学习路径</p>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="dir-filter-bar">
      <div class="dir-filter-inner">
        <div class="dir-tabs" id="dir-tabs">
          <button class="dir-tab active" data-module="all">全部</button>
          {modules.map(mod => (
            <button class="dir-tab" data-module={mod.prefix} style={`--tab-color: ${mod.color}`}>
              {mod.name}
            </button>
          ))}
        </div>
        <div class="dir-search-wrap">
          <input type="text" class="dir-search" id="dir-search" placeholder="搜索文章标题..." />
        </div>
      </div>
    </div>

    <!-- Article listing -->
    <div class="dir-body">
      {moduleData.map(mod => (
        <div class="dir-module" data-module={mod.prefix}>
          <div class="dir-module-header">
            <span class="dir-module-badge" style={`background: ${mod.color}`}>{mod.prefix.toUpperCase()}</span>
            <h2>{mod.name}</h2>
            <span class="dir-module-count">{mod.lessons.length} 篇</span>
          </div>

          {[...mod.groups.entries()].map(([groupName, groupLessons]) => (
            <div class="dir-group">
              <div class="dir-group-label">{groupName}</div>
              <div class="dir-group-list">
                {groupLessons.map(lesson => (
                  <a class="dir-item" href={lessonUrl(lesson.id)} data-title={lesson.data.title}>
                    <span class="dir-item-num">{String(lesson.data.order).padStart(2, '0')}</span>
                    <span class="dir-item-title">{lesson.data.title}</span>
                    <span class="dir-item-meta">
                      <span class="dir-item-level">{lesson.data.level}</span>
                      <span class="dir-item-duration">{lesson.data.duration}</span>
                    </span>
                    <span class="dir-item-arrow">&rarr;</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ))}

      <!-- Empty state -->
      <div class="dir-empty" id="dir-empty" style="display:none;">
        <p>没有找到匹配的文章</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.dir-tab');
  const modules = document.querySelectorAll<HTMLElement>('.dir-module');
  const searchInput = document.getElementById('dir-search') as HTMLInputElement;
  const emptyState = document.getElementById('dir-empty')!;

  let activeModule = 'all';
  let searchQuery = '';

  function applyFilters() {
    let visibleCount = 0;

    modules.forEach(mod => {
      const moduleId = mod.dataset.module!;
      const moduleMatch = activeModule === 'all' || moduleId === activeModule;

      if (!moduleMatch) {
        mod.style.display = 'none';
        return;
      }

      mod.style.display = '';
      const items = mod.querySelectorAll<HTMLElement>('.dir-item');
      const groups = mod.querySelectorAll<HTMLElement>('.dir-group');

      // Track visible items per group
      const groupVisibility = new Map<HTMLElement, number>();
      groups.forEach(g => groupVisibility.set(g, 0));

      items.forEach(item => {
        const title = (item.dataset.title || '').toLowerCase();
        const match = !searchQuery || title.includes(searchQuery);
        item.style.display = match ? '' : 'none';
        if (match) {
          visibleCount++;
          const parentGroup = item.closest('.dir-group') as HTMLElement;
          if (parentGroup) {
            groupVisibility.set(parentGroup, (groupVisibility.get(parentGroup) || 0) + 1);
          }
        }
      });

      // Hide groups with no visible items
      groupVisibility.forEach((count, group) => {
        group.style.display = count > 0 ? '' : 'none';
      });

      // Hide entire module if no items visible
      const moduleVisible = Array.from(items).some(i => i.style.display !== 'none');
      if (!moduleVisible) mod.style.display = 'none';
    });

    emptyState.style.display = visibleCount === 0 ? '' : 'none';
  }

  // Tab click
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      activeModule = tab.dataset.module!;
      applyFilters();
    });
  });

  // Search input
  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    applyFilters();
  });
</script>

<style>
  .dir-page {
    padding-top: 64px;
  }

  /* Header */
  .dir-header {
    background: linear-gradient(135deg, var(--ink) 0%, #2a2520 100%);
    color: #fff;
    padding: 28px 40px 40px;
  }
  .dir-header-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .dir-back {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 20px;
    transition: color 0.2s;
  }
  .dir-back:hover {
    color: #fff;
  }
  .dir-header h1 {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 10px;
    letter-spacing: -0.02em;
  }
  .dir-subtitle {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }

  /* Filter bar */
  .dir-filter-bar {
    position: sticky;
    top: 64px;
    z-index: 50;
    background: rgba(246, 243, 237, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--gray-200);
    padding: 0 40px;
  }
  .dir-filter-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0;
  }
  .dir-tabs {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    flex: 1;
  }
  .dir-tab {
    padding: 6px 14px;
    border: 1px solid var(--gray-200);
    border-radius: 6px;
    background: transparent;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray-500);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--sans);
    white-space: nowrap;
  }
  .dir-tab:hover {
    border-color: var(--gray-400);
    color: var(--ink);
  }
  .dir-tab.active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .dir-search-wrap {
    flex-shrink: 0;
  }
  .dir-search {
    padding: 7px 14px;
    border: 1px solid var(--gray-200);
    border-radius: 6px;
    font-size: 13px;
    background: #fff;
    color: var(--ink);
    width: 180px;
    font-family: var(--sans);
    outline: none;
    transition: border-color 0.2s;
  }
  .dir-search:focus {
    border-color: var(--accent);
  }
  .dir-search::placeholder {
    color: var(--gray-400);
  }

  /* Body */
  .dir-body {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 40px 80px;
  }

  /* Module section */
  .dir-module {
    margin-bottom: 40px;
  }
  .dir-module-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .dir-module-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--mono);
    color: #fff;
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .dir-module-header h2 {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 700;
  }
  .dir-module-count {
    font-size: 13px;
    color: var(--gray-400);
  }

  /* Group */
  .dir-group {
    margin-bottom: 20px;
  }
  .dir-group-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gray-400);
    margin-bottom: 8px;
    padding-left: 4px;
  }
  .dir-group-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--gray-200);
    border-radius: 10px;
    overflow: hidden;
  }

  /* Item row */
  .dir-item {
    display: grid;
    grid-template-columns: 36px 1fr auto 24px;
    gap: 12px;
    align-items: center;
    padding: 14px 20px;
    background: #fff;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s;
  }
  .dir-item:hover {
    background: var(--gray-100);
  }
  .dir-item:hover .dir-item-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
  .dir-item-num {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-300);
    text-align: center;
  }
  .dir-item-title {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
  }
  .dir-item-meta {
    display: flex;
    gap: 10px;
    font-size: 12px;
    color: var(--gray-400);
    white-space: nowrap;
  }
  .dir-item-level {
    padding: 2px 8px;
    background: var(--gray-100);
    border-radius: 4px;
    font-weight: 500;
  }
  .dir-item-arrow {
    font-size: 14px;
    color: var(--gray-300);
    transition: all 0.2s;
  }

  /* Empty state */
  .dir-empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--gray-400);
    font-size: 15px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .dir-header {
      padding: 20px 20px 32px;
    }
    .dir-header h1 {
      font-size: 24px;
    }
    .dir-filter-bar {
      padding: 0 16px;
    }
    .dir-filter-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      padding: 10px 0;
    }
    .dir-tabs {
      gap: 4px;
    }
    .dir-tab {
      padding: 5px 10px;
      font-size: 12px;
    }
    .dir-search {
      width: 100%;
    }
    .dir-body {
      padding: 20px 16px 60px;
    }
    .dir-item {
      grid-template-columns: 28px 1fr 20px;
      padding: 12px 14px;
      gap: 8px;
    }
    .dir-item-meta {
      display: none;
    }
    .dir-module-header h2 {
      font-size: 18px;
    }
  }
</style>
