---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);

const modules = [
  { id: 'm1-basics',   name: '入门篇',   icon: '01', color: '#2d8a56', prefix: 'm1' },
  { id: 'm2-thinking', name: '思维篇',   icon: '02', color: '#c44b2b', prefix: 'm2' },
  { id: 'm3-practice', name: '实战篇',   icon: '03', color: '#2b6cc4', prefix: 'm3' },
  { id: 'm4-advanced', name: '进阶篇',   icon: '04', color: '#7c3aed', prefix: 'm4' },
  { id: 'm5-compare',  name: '工具对比', icon: '05', color: '#d97706', prefix: 'm5' },
  { id: 'm6-sidebiz',  name: '副业指南', icon: '06', color: '#0891b2', prefix: 'm6' },
];

const moduleData = modules.map(mod => {
  const lessons = allLessons
    .filter(l => l.data.module === mod.id)
    .sort((a, b) => a.data.order - b.data.order);
  return { ...mod, lessons };
});

const totalCount = allLessons.length;

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}
---

<BaseLayout
  title="全部文章目录 - Claude Code 精通之路"
  description="Claude Code 精通之路全站文章目录，按模块分类浏览所有教程，快速定位你需要的内容。"
>
  <div class="dir-page">
    <!-- Header -->
    <div class="dir-header">
      <div class="dir-header-inner">
        <a class="dir-back" href="/">&larr; 返回首页</a>
        <h1>全部文章目录</h1>
        <p class="dir-subtitle">共 <strong>{totalCount}</strong> 篇文章 · 6 大模块 · 涵盖入门到进阶的完整路径</p>
        <!-- Search -->
        <div class="dir-search-wrap">
          <svg class="dir-search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8.5" cy="8.5" r="5.5"/><path d="M13 13l4 4"/></svg>
          <input type="text" class="dir-search" id="dir-search" placeholder="搜索文章标题..." />
        </div>
      </div>
    </div>

    <!-- Ranking grid -->
    <div class="dir-grid">
      {moduleData.map((mod, mi) => (
        <div class="rank-card" data-module={mod.prefix} style={`--card-color: ${mod.color}`}>
          <div class="rank-header">
            <a class="rank-title-link" href={`/${mod.prefix}`}>
              <span class="rank-icon">{mod.icon}</span>
              <h2>{mod.name}</h2>
              <span class="rank-count">{mod.lessons.length} 篇</span>
            </a>
          </div>
          <div class="rank-list">
            {mod.lessons.map((lesson, i) => (
              <a class="rank-item" href={lessonUrl(lesson.id)} data-title={lesson.data.title}>
                <span class={`rank-num ${i < 3 ? 'top' : ''}`}>{i + 1}</span>
                <span class="rank-item-title">{lesson.data.title}</span>
                <span class="rank-item-tag">{lesson.data.level}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div class="dir-empty" id="dir-empty" style="display:none;">
      <p>没有找到匹配的文章</p>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('dir-search') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('.rank-card');
  const emptyState = document.getElementById('dir-empty')!;

  searchInput.addEventListener('input', () => {
    const query = searchInput.value.trim().toLowerCase();
    let totalVisible = 0;

    cards.forEach(card => {
      const items = card.querySelectorAll<HTMLElement>('.rank-item');
      let cardVisible = 0;

      items.forEach(item => {
        const title = (item.dataset.title || '').toLowerCase();
        const match = !query || title.includes(query);
        item.style.display = match ? '' : 'none';
        if (match) cardVisible++;
      });

      card.style.display = cardVisible > 0 ? '' : 'none';
      totalVisible += cardVisible;
    });

    emptyState.style.display = totalVisible === 0 ? '' : 'none';
  });
</script>

<style>
  .dir-page {
    padding-top: 64px;
  }

  /* Header */
  .dir-header {
    background: linear-gradient(135deg, var(--ink) 0%, #2a2520 100%);
    color: #fff;
    padding: 28px 40px 36px;
  }
  .dir-header-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .dir-back {
    color: rgba(255, 255, 255, 0.55);
    font-size: 14px;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 18px;
    transition: color 0.2s;
  }
  .dir-back:hover { color: #fff; }
  .dir-header h1 {
    font-family: var(--serif);
    font-size: 30px;
    font-weight: 800;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .dir-subtitle {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .dir-subtitle strong {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
  }

  /* Search in header */
  .dir-search-wrap {
    position: relative;
    max-width: 360px;
  }
  .dir-search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    color: rgba(255, 255, 255, 0.4);
    pointer-events: none;
  }
  .dir-search {
    width: 100%;
    padding: 9px 14px 9px 36px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    font-size: 14px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-family: var(--sans);
    outline: none;
    transition: all 0.2s;
  }
  .dir-search:focus {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.12);
  }
  .dir-search::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  /* Grid */
  .dir-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 40px 80px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* Rank card */
  .rank-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--gray-200);
    transition: box-shadow 0.25s;
  }
  .rank-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  /* Card header */
  .rank-header {
    border-bottom: 1px solid var(--gray-200);
  }
  .rank-title-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s;
  }
  .rank-title-link:hover {
    background: var(--gray-100);
  }
  .rank-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--card-color);
    color: #fff;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .rank-header h2 {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 700;
    flex: 1;
  }
  .rank-count {
    font-size: 12px;
    color: var(--gray-400);
    flex-shrink: 0;
  }

  /* List */
  .rank-list {
    padding: 6px 0;
  }

  /* Item */
  .rank-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.12s;
  }
  .rank-item:hover {
    background: var(--gray-100);
  }

  /* Rank number */
  .rank-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--gray-400);
    background: var(--gray-100);
    flex-shrink: 0;
    line-height: 1;
  }
  .rank-num.top {
    background: var(--card-color);
    color: #fff;
  }

  /* Title */
  .rank-item-title {
    flex: 1;
    font-size: 14px;
    font-weight: 450;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Tag */
  .rank-item-tag {
    font-size: 11px;
    color: var(--gray-400);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Empty */
  .dir-empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--gray-400);
    font-size: 15px;
  }

  /* ---- Responsive ---- */

  /* Tablet: 2 columns */
  @media (max-width: 960px) {
    .dir-grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 24px 24px 60px;
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 600px) {
    .dir-header {
      padding: 20px 20px 28px;
    }
    .dir-header h1 {
      font-size: 24px;
    }
    .dir-subtitle {
      font-size: 14px;
    }
    .dir-search-wrap {
      max-width: 100%;
    }
    .dir-grid {
      grid-template-columns: 1fr;
      padding: 16px 16px 60px;
      gap: 16px;
    }
    .rank-item {
      padding: 8px 14px;
    }
    .rank-item-title {
      font-size: 13px;
    }
  }
</style>
