---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import '../styles/terminal.css';
import { getCollection } from 'astro:content';

// Get all published lessons for the article list
const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const sortedLessons = allLessons.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentLessons = sortedLessons.slice(0, 5);

// Count lessons per module
const m1Count = allLessons.filter(l => l.data.module === 'm1-basics').length;
const m2Count = allLessons.filter(l => l.data.module === 'm2-thinking').length;
const m3Count = allLessons.filter(l => l.data.module === 'm3-practice').length;
const m4Count = allLessons.filter(l => l.data.module === 'm4-advanced').length;
const totalCount = allLessons.length;

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}

const moduleNames: Record<string, string> = {
  'm1-basics': '基础篇',
  'm2-thinking': '思维篇',
  'm3-practice': '实战篇',
  'm4-advanced': '进阶篇',
};
---

<BaseLayout
  title="Claude Code 精通之路 — 一个开发者的 AI 编程实战笔记"
  description="记录使用 Claude Code 进行真实项目开发的经验、踩坑与思考。不讲花哨技巧，只写工程实践中真正有用的东西。"
>

<!-- Hero -->
<section class="hero">
  <div>
    <div class="hero-badge">持续更新的实战笔记</div>
    <h1>一个开发者的<br><span class="hl">AI 编程</span>实战记录</h1>
    <p class="hero-desc">这里记录了我用 Claude Code 做真实项目的全过程——怎么拆需求、怎么管理上下文、什么时候该让 AI 写代码、什么时候该自己来。没有"十倍效率"的噱头，只有一步步趟出来的实际经验。</p>
    <div class="hero-actions">
      <a class="btn-primary" href="/m1/01-what-is-claude-code">从头开始读</a>
      <a class="btn-secondary" href="/m2/01-why-prompts-fall-short">直接看思维篇</a>
    </div>
  </div>
  <Terminal>
    <div><span class="t-comment"># 真实场景：重构一个认证模块</span></div>
    <div><span class="t-green">$ </span><span class="t-blue">claude</span> <span class="t-orange">"重构 auth 模块，</span></div>
    <div><span class="t-orange">&nbsp;&nbsp;拆分为 login / register / token</span></div>
    <div><span class="t-orange">&nbsp;&nbsp;三个独立服务，保持现有接口不变"</span></div><br>
    <div><span class="t-purple">-- 分析现有代码结构</span></div>
    <div><span class="t-purple">-- 识别 12 个内部依赖</span></div>
    <div><span class="t-purple">-- 生成重构方案</span></div>
    <div><span class="t-purple">-- 拆分为 3 个服务模块</span></div>
    <div><span class="t-purple">-- 同步更新 8 个测试用例</span></div><br>
    <div><span class="t-comment"># prompt 写得再花哨也没用</span></div>
    <div><span class="t-comment"># 关键是你自己先把需求想清楚</span></div><br>
    <div><span class="t-green">$ </span><span class="cursor-blink"></span></div>
  </Terminal>
</section>

<!-- Stats -->
<div class="stats">
  <div class="stat-item">
    <div class="stat-number">{totalCount}+</div>
    <div class="stat-label">篇原创教程</div>
  </div>
  <div class="stat-item">
    <div class="stat-number">{m1Count + m2Count > 10 ? '10+' : m1Count + m2Count}</div>
    <div class="stat-label">个实战案例</div>
  </div>
  <div class="stat-item">
    <div class="stat-number">CLI</div>
    <div class="stat-label">命令行优先的工作流</div>
  </div>
  <div class="stat-item">
    <div class="stat-number">开源</div>
    <div class="stat-label">所有内容免费阅读</div>
  </div>
</div>

<!-- Tutorial Grid -->
<section class="section fade-in">
  <div class="section-label">教程目录</div>
  <h2 class="section-title">从零基础到工程化实践</h2>
  <p class="section-desc">我把自己的学习路径整理成了两个系列，从安装配置讲到架构决策。每篇都带真实的代码场景和踩坑记录。</p>
  <div class="course-grid">
    <a class="course-card" href="/m1/01-what-is-claude-code">
      <div class="course-icon i-g">01</div>
      <div class="tag tag-g">基础篇</div>
      <h3>环境搭建与核心工作流</h3>
      <p>从安装 CLI 开始，搞定环境配置、文件操作、prompt 基本功。写了 8 篇，覆盖了新手最容易卡住的那些问题。</p>
      <div class="course-meta"><span>{m1Count} 篇</span><span>约 3 小时</span><span>零基础可读</span></div>
    </a>
    <a class="course-card" href="/m2/01-why-prompts-fall-short">
      <div class="course-icon i-a">02</div>
      <div class="tag tag-a">思维篇</div>
      <h3>软件工程思维与协作策略</h3>
      <p>这部分是我花时间最多的——怎么拆任务、管上下文、做代码审查、处理 AI 犯的错。想用好 Claude Code，思维比技巧重要。</p>
      <div class="course-meta"><span>{m2Count} 篇</span><span>约 5 小时</span><span>需编程基础</span></div>
    </a>
    <a class="course-card" href="/m3/01-build-project-from-scratch">
      <div class="course-icon i-b">03</div>
      <div class="tag tag-b">实战篇</div>
      <h3>真实项目开发复盘</h3>
      <p>从零搭建项目、重构 400 行巨型组件、排查线上内存泄漏、一个月使用数据复盘——每篇都是完整的实战记录，附踩坑和修复过程。</p>
      <div class="course-meta"><span>{m3Count} 篇</span><span>约 4 小时</span><span>需编程基础</span></div>
    </a>
    <a class="course-card" href="/m4/01-headless-mode">
      <div class="course-icon i-p">04</div>
      <div class="tag tag-p">进阶篇</div>
      <h3>自动化与深度集成</h3>
      <p>Headless 模式、管道操作、Git Hook 集成、批量处理——把 Claude Code 从对话工具变成可编程的自动化引擎。</p>
      <div class="course-meta"><span>{m4Count} 篇</span><span>持续更新</span><span>需编程基础</span></div>
    </a>
  </div>
</section>

<!-- Why This Site -->
<section class="philosophy-bg">
  <div class="section fade-in">
    <div class="section-label" style="color: var(--accent-light)">写作初衷</div>
    <h2 class="section-title" style="color: var(--paper)">为什么要写这些</h2>
    <p class="section-desc" style="color: var(--gray-400); margin-bottom: 48px;">用了半年 Claude Code，踩了不少坑，也摸索出一些真正管用的方法。写下来，一方面给自己做备忘，一方面希望对你也有帮助。</p>
    <div class="phil-grid">
      <div class="phil-card">
        <div class="phil-num">01</div>
        <h3>工具只是放大器</h3>
        <p>如果你不会拆解问题，prompt 写得再漂亮也没用。Claude Code 放大的是你的工程能力，不是取代它。我在教程里反复强调这一点。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">02</div>
        <h3>命令行才是主场</h3>
        <p>桌面版适合快速提问，但真正做项目还得靠 CLI。它能和 git、docker、CI/CD 串起来，这才是工程化的用法。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">03</div>
        <h3>踩过的坑最值钱</h3>
        <p>每篇教程里都有我实际遇到的问题和解决过程。比起教你"正确做法"，我更想让你看到"我是怎么一步步试出来的"。</p>
      </div>
    </div>
  </div>
</section>

<!-- Recent Articles -->
<section class="section fade-in">
  <div class="section-label">最近更新</div>
  <h2 class="section-title">最新发布的文章</h2>
  <p class="section-desc">按发布时间倒序排列，点击标题直接阅读。</p>
  <div class="article-list">
    {recentLessons.map((lesson, i) => (
      <a class="article-item" href={lessonUrl(lesson.id)}>
        <span class="a-num">{String(i + 1).padStart(2, '0')}</span>
        <div class="a-info">
          <h4>{lesson.data.title}</h4>
          <p>{moduleNames[lesson.data.module]} / {lesson.data.duration}</p>
        </div>
        <span class="a-arrow">&rarr;</span>
      </a>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="cta-section fade-in">
  <h2>从第一篇开始读</h2>
  <p>不需要任何 AI 编程经验。从安装 Claude Code 开始，一步步带你搭建自己的 AI 编程工作流。所有内容免费，随时可以开始。</p>
  <a class="btn-primary" style="font-size: 16px; padding: 16px 36px;" href="/m1/01-what-is-claude-code">阅读第一篇教程</a>
</section>

</BaseLayout>
