---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import '../styles/terminal.css';
import { getCollection } from 'astro:content';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const sortedLessons = allLessons.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentLessons = sortedLessons.slice(0, 8);
const totalCount = allLessons.length;

const moduleCounts: Record<string, number> = {};
allLessons.forEach(l => {
  moduleCounts[l.data.module] = (moduleCounts[l.data.module] || 0) + 1;
});

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}

const moduleNames: Record<string, string> = {
  'm1-basics': '入门篇',
  'm2-thinking': '思维篇',
  'm3-practice': '实战篇',
  'm4-advanced': '进阶篇',
  'm5-compare': '工具对比',
  'm6-sidebiz': '副业指南',
};

const modules = [
  { id: 'm1-basics', name: '入门篇', desc: '新手从 0 到 1', detail: '安装配置、核心命令、Prompt 写法、MCP 入门、费用攻略——零基础也能跟上。', color: '#2d8a56', href: '/m1' },
  { id: 'm3-practice', name: '实战篇', desc: '深度项目案例', detail: '从零搭建项目、重构复盘、线上排查、数据工程、CI/CD 自动化——每篇都是完整记录。', color: '#2b6cc4', href: '/m3' },
  { id: 'm5-compare', name: '工具对比', desc: '横评与选型', detail: 'Claude Code vs Cursor vs Copilot vs Windsurf，模型选型、API vs 订阅——帮你做出最优选择。', color: '#d97706', href: '/m5' },
  { id: 'm6-sidebiz', name: '副业指南', desc: 'AI 赚钱实操方法论', detail: '搭建副业网站、AdSense 变现、AI 接单提效、公众号运营——用 AI 开启技术变现之路。', color: '#059669', href: '/m6' },
];
---

<BaseLayout
  title="Claude Code 精通之路 — AI 编程实战教程"
  description="最全面的 Claude Code 中文教程站。从入门到实战，工具对比到副业变现，帮你真正掌握 AI 编程。"
>

<!-- Hero -->
<section class="hero">
  <div>
    <div class="hero-badge">持续更新 · {totalCount} 篇原创教程</div>
    <h1>用 <span class="hl">Claude Code</span><br>做真实项目的实战记录</h1>
    <p class="hero-desc">从安装配置到项目实战，从工具选型到副业变现。不讲花哨技巧，只写工程实践中真正有用的东西。</p>
    <div class="hero-actions">
      <a class="btn-primary" href="/m1">从零开始学</a>
      <a class="btn-secondary" href="/m3">直接看实战</a>
    </div>
  </div>
  <Terminal>
    <div><span class="t-comment"># 真实场景：重构一个认证模块</span></div>
    <div><span class="t-green">$ </span><span class="t-blue">claude</span> <span class="t-orange">"重构 auth 模块，</span></div>
    <div><span class="t-orange">&nbsp;&nbsp;拆分为 login / register / token</span></div>
    <div><span class="t-orange">&nbsp;&nbsp;三个独立服务，保持现有接口不变"</span></div><br>
    <div><span class="t-purple">-- 分析现有代码结构</span></div>
    <div><span class="t-purple">-- 识别 12 个内部依赖</span></div>
    <div><span class="t-purple">-- 生成重构方案</span></div>
    <div><span class="t-purple">-- 拆分为 3 个服务模块</span></div>
    <div><span class="t-purple">-- 同步更新 8 个测试用例</span></div><br>
    <div><span class="t-comment"># prompt 写得再花哨也没用</span></div>
    <div><span class="t-comment"># 关键是你自己先把需求想清楚</span></div><br>
    <div><span class="t-green">$ </span><span class="cursor-blink"></span></div>
  </Terminal>
</section>

<!-- Module Cards -->
<section class="section fade-in">
  <div class="section-label">教程目录</div>
  <h2 class="section-title">选择你的学习路径</h2>
  <p class="section-desc">四大板块，覆盖从入门到变现的完整链路。每个板块独立成篇，按需阅读。</p>
  <div class="course-grid">
    {modules.map((mod, i) => (
      <a class="course-card" href={mod.href}>
        <div class="course-icon" style={`background: ${mod.color}`}>{String(i + 1).padStart(2, '0')}</div>
        <div class="tag" style={`color: ${mod.color}; border-color: ${mod.color}`}>{mod.name}</div>
        <h3>{mod.desc}</h3>
        <p>{mod.detail}</p>
        <div class="course-meta">
          <span>{moduleCounts[mod.id] || 0} 篇</span>
          <span>持续更新</span>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- More Modules -->
<section class="section fade-in" style="padding-top: 0;">
  <div class="more-modules">
    <a class="more-module-card" href="/m2">
      <div class="mmc-badge" style="background: #c44b2b">思维篇</div>
      <div class="mmc-info">
        <h4>软件工程思维与协作策略</h4>
        <p>任务拆解、上下文管理、代码审查、架构决策——{moduleCounts['m2-thinking'] || 0} 篇深度内容</p>
      </div>
      <span class="mmc-arrow">&rarr;</span>
    </a>
    <a class="more-module-card" href="/m4">
      <div class="mmc-badge" style="background: #8b5cf6">进阶篇</div>
      <div class="mmc-info">
        <h4>自动化与深度集成</h4>
        <p>Headless 模式、管道操作、Git Hook 集成——{moduleCounts['m4-advanced'] || 0} 篇进阶内容</p>
      </div>
      <span class="mmc-arrow">&rarr;</span>
    </a>
  </div>
</section>

<!-- Why This Site -->
<section class="philosophy-bg">
  <div class="section fade-in">
    <div class="section-label" style="color: var(--accent-light)">写作初衷</div>
    <h2 class="section-title" style="color: var(--paper)">为什么要写这些</h2>
    <p class="section-desc" style="color: var(--gray-400); margin-bottom: 48px;">用了半年 Claude Code，踩了不少坑，也摸索出一些真正管用的方法。写下来，一方面给自己做备忘，一方面希望对你也有帮助。</p>
    <div class="phil-grid">
      <div class="phil-card">
        <div class="phil-num">01</div>
        <h3>工具只是放大器</h3>
        <p>如果你不会拆解问题，prompt 写得再漂亮也没用。Claude Code 放大的是你的工程能力，不是取代它。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">02</div>
        <h3>命令行才是主场</h3>
        <p>桌面版适合快速提问，但真正做项目还得靠 CLI。它能和 git、docker、CI/CD 串起来，这才是工程化的用法。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">03</div>
        <h3>踩过的坑最值钱</h3>
        <p>每篇教程里都有我实际遇到的问题和解决过程。比起教你"正确做法"，我更想让你看到"我是怎么一步步试出来的"。</p>
      </div>
    </div>
  </div>
</section>

<!-- Recent Articles -->
<section class="section fade-in">
  <div class="section-label">最近更新</div>
  <h2 class="section-title">最新发布的文章</h2>
  <p class="section-desc">按发布时间倒序排列，点击标题直接阅读。</p>
  <div class="article-list">
    {recentLessons.map((lesson, i) => (
      <a class="article-item" href={lessonUrl(lesson.id)}>
        <span class="a-num">{String(i + 1).padStart(2, '0')}</span>
        <div class="a-info">
          <h4>{lesson.data.title}</h4>
          <p>{moduleNames[lesson.data.module]} / {lesson.data.duration}</p>
        </div>
        <span class="a-arrow">&rarr;</span>
      </a>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="cta-section fade-in">
  <h2>从第一篇开始读</h2>
  <p>不需要任何 AI 编程经验。从安装 Claude Code 开始，一步步带你搭建自己的 AI 编程工作流。所有内容免费，随时可以开始。</p>
  <a class="btn-primary" style="font-size: 16px; padding: 16px 36px;" href="/m1">阅读入门篇</a>
</section>

</BaseLayout>

<style>
  .more-modules {
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: var(--gray-200);
    border-radius: 12px;
    overflow: hidden;
  }
  .more-module-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 20px 24px;
    background: var(--paper);
    text-decoration: none;
    color: var(--ink);
    transition: background .2s;
  }
  .more-module-card:hover {
    background: #faf8f4;
  }
  .more-module-card:hover .mmc-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }
  .mmc-badge {
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 8px;
    white-space: nowrap;
  }
  .mmc-info h4 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .mmc-info p {
    font-size: 13px;
    color: var(--gray);
  }
  .mmc-arrow {
    font-size: 18px;
    color: var(--gray-300);
    transition: all .2s;
  }
  .course-icon {
    color: #fff;
    font-family: var(--mono);
    font-weight: 700;
  }
  .tag {
    border: 1.5px solid;
    background: transparent;
  }

  @media (max-width: 768px) {
    .more-module-card {
      grid-template-columns: 1fr auto;
      padding: 16px;
    }
    .mmc-badge {
      display: none;
    }
  }
</style>
