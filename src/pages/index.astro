---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/terminal.css';
import { getCollection } from 'astro:content';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const totalCount = allLessons.length;

const sortedByDate = [...allLessons].sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentTwo = sortedByDate.slice(0, 2);

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}

const modules = [
  { id: 'm1-basics',   name: '入门篇',   desc: '安装配置 · 核心命令 · Prompt 写法',   icon: '01', color: '#2d8a56', prefix: 'm1' },
  { id: 'm2-thinking', name: '思维篇',   desc: '任务拆解 · 上下文管理 · 架构决策',    icon: '02', color: '#c44b2b', prefix: 'm2' },
  { id: 'm3-practice', name: '实战篇',   desc: '建项目 · 重构 · 调试 · CI/CD',        icon: '03', color: '#2b6cc4', prefix: 'm3' },
  { id: 'm4-advanced', name: '进阶篇',   desc: 'Headless 模式 · 源码解读',             icon: '04', color: '#7c3aed', prefix: 'm4' },
  { id: 'm5-compare',  name: '工具对比', desc: 'vs Cursor · vs Copilot · 选型指南',    icon: '05', color: '#d97706', prefix: 'm5' },
  { id: 'm6-sidebiz',  name: '副业指南', desc: 'AI 建站 · AdSense · 接单变现',         icon: '06', color: '#0891b2', prefix: 'm6' },
];

const moduleData = modules.map(mod => {
  const lessons = allLessons
    .filter(l => l.data.module === mod.id)
    .sort((a, b) => a.data.order - b.data.order);
  return { ...mod, lessons };
});
---

<BaseLayout
  title="Claude Code 精通之路 — AI 编程实战教程"
  description="最全面的 Claude Code 中文教程站。从入门到实战，工具对比到副业变现，帮你真正掌握 AI 编程。"
>

<!-- Hero -->
<section class="hero-banner">
  <div class="hero-inner">
    <h1><span class="hero-hl">Claude Code</span> 精通之路</h1>
    <p class="hero-tagline">从入门到实战的 AI 编程完整教程 · 共 <strong>{totalCount}</strong> 篇 · 持续更新中</p>
    <div class="hero-row">
      <a class="btn-primary btn-hero" href="/m1">从零开始学 &rarr;</a>
      <span class="hero-divider"></span>
      <div class="hero-recent-col">
        {recentTwo.map((lesson, i) => (
          <a class="hero-recent-item" href={lessonUrl(lesson.id)}>
            {i === 0 && <span class="hero-new-badge">NEW</span>}
            <span class="hero-recent-title">{lesson.data.title}</span>
            <span class="hero-recent-date">{lesson.data.publishedAt.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Main: Article Directory -->
<section class="dir-section" id="directory">
  <div class="dir-inner">
    <div class="dir-top">
      <div class="dir-heading">
        <h2>全部文章</h2>
        <span class="dir-total">{totalCount} 篇 · 6 个模块</span>
      </div>
      <div class="dir-search-wrap">
        <svg class="dir-search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8.5" cy="8.5" r="5.5"/><path d="M13 13l4 4"/></svg>
        <input type="text" class="dir-search" id="dir-search" placeholder="搜索文章标题..." />
      </div>
    </div>

    <div class="rank-grid">
      {moduleData.map(mod => (
        <div class="rank-card" data-module={mod.prefix} style={`--card-color: ${mod.color}`}>
          <a class="rank-header" href={`/${mod.prefix}`}>
            <span class="rank-icon">{mod.icon}</span>
            <div class="rank-header-text">
              <h3>{mod.name}<span class="rank-count">{mod.lessons.length}</span></h3>
              <p class="rank-desc">{mod.desc}</p>
            </div>
          </a>
          <div class="rank-list">
            {mod.lessons.map((lesson, i) => (
              <a class="rank-item" href={lessonUrl(lesson.id)} data-title={lesson.data.title} style={i >= 10 ? 'display:none' : ''} data-extra={i >= 10 ? 'true' : undefined}>
                <span class={`rank-num ${i < 3 ? 'top' : ''}`}>{i + 1}</span>
                <span class="rank-item-title">{lesson.data.title}</span>
                <span class="rank-item-tag">{lesson.data.level}</span>
              </a>
            ))}
          </div>
          {mod.lessons.length > 10 && (
            <button class="rank-expand" data-target={mod.prefix}>
              展开全部 {mod.lessons.length} 篇
            </button>
          )}
        </div>
      ))}
    </div>

    <div class="dir-empty" id="dir-empty" style="display:none;">
      没有找到匹配的文章
    </div>
  </div>
</section>

<!-- Why This Site (compact) -->
<section class="philosophy-bg">
  <div class="section fade-in">
    <div class="section-label" style="color: var(--accent-light)">写作初衷</div>
    <h2 class="section-title" style="color: var(--paper)">为什么要写这些</h2>
    <p class="section-desc" style="color: var(--gray-400); margin-bottom: 48px;">用了半年 Claude Code，踩了不少坑，也摸索出一些真正管用的方法。写下来，一方面给自己做备忘，一方面希望对你也有帮助。</p>
    <div class="phil-grid">
      <div class="phil-card">
        <div class="phil-num">01</div>
        <h3>工具只是放大器</h3>
        <p>如果你不会拆解问题，prompt 写得再漂亮也没用。Claude Code 放大的是你的工程能力，不是取代它。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">02</div>
        <h3>命令行才是主场</h3>
        <p>桌面版适合快速提问，但真正做项目还得靠 CLI。它能和 git、docker、CI/CD 串起来，这才是工程化的用法。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">03</div>
        <h3>踩过的坑最值钱</h3>
        <p>每篇教程里都有我实际遇到的问题和解决过程。比起教你"正确做法"，我更想让你看到"我是怎么一步步试出来的"。</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section fade-in">
  <h2>从第一篇开始读</h2>
  <p>不需要任何 AI 编程经验。从安装 Claude Code 开始，一步步带你搭建自己的 AI 编程工作流。所有内容免费，随时可以开始。</p>
  <a class="btn-primary" style="font-size: 16px; padding: 16px 36px;" href="/m1">阅读入门篇</a>
</section>

</BaseLayout>

<script>
  const searchInput = document.getElementById('dir-search') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('.rank-card');
  const emptyState = document.getElementById('dir-empty')!;

  searchInput.addEventListener('input', () => {
    const query = searchInput.value.trim().toLowerCase();
    let totalVisible = 0;

    cards.forEach(card => {
      const items = card.querySelectorAll<HTMLElement>('.rank-item');
      let cardVisible = 0;

      items.forEach(item => {
        const title = (item.dataset.title || '').toLowerCase();
        const match = !query || title.includes(query);
        item.style.display = match ? '' : 'none';
        if (match) cardVisible++;
      });

      card.style.display = cardVisible > 0 ? '' : 'none';
      totalVisible += cardVisible;
    });

    emptyState.style.display = totalVisible === 0 ? '' : 'none';
  });

  // Expand button
  document.querySelectorAll<HTMLButtonElement>('.rank-expand').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target!;
      const card = document.querySelector<HTMLElement>(`.rank-card[data-module="${target}"]`);
      if (!card) return;
      card.querySelectorAll<HTMLElement>('.rank-item[data-extra]').forEach(item => {
        item.style.display = '';
      });
      btn.remove();
    });
  });
</script>

<style>
  /* ========== Hero Banner ========== */
  .hero-banner {
    padding-top: 64px;
    background: linear-gradient(135deg, var(--ink) 0%, #2a2520 100%);
    color: #fff;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 40px 40px;
    text-align: center;
  }
  .hero-inner h1 {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .hero-hl {
    color: var(--accent-light);
  }
  .hero-tagline {
    font-size: 15px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 28px;
  }
  .hero-tagline strong {
    color: rgba(255,255,255,0.8);
  }

  /* Hero row: button + recent links */
  .hero-row {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-hero {
    padding: 12px 28px !important;
    font-size: 15px !important;
    flex-shrink: 0;
  }
  .hero-divider {
    width: 1px;
    height: 24px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }
  .hero-recent-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: rgba(255,255,255,0.6);
    font-size: 14px;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .hero-recent-item:hover {
    color: #fff;
  }
  .hero-new-badge {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--accent);
    border-radius: 4px;
    padding: 2px 6px;
    flex-shrink: 0;
    line-height: 1.4;
  }
  .hero-recent-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hero-recent-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .hero-recent-date {
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 12px;
    opacity: 0.35;
  }

  /* ========== Directory Section ========== */
  .dir-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 40px 60px;
  }
  .dir-inner {}
  .dir-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 20px;
  }
  .dir-heading {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .dir-heading h2 {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 800;
  }
  .dir-total {
    font-size: 13px;
    color: var(--gray-400);
  }
  .dir-search-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .dir-search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 15px;
    height: 15px;
    color: var(--gray-400);
    pointer-events: none;
  }
  .dir-search {
    padding: 8px 14px 8px 32px;
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    font-size: 13px;
    background: #fff;
    color: var(--ink);
    width: 220px;
    font-family: var(--sans);
    outline: none;
    transition: border-color 0.2s;
  }
  .dir-search:focus {
    border-color: var(--accent);
  }
  .dir-search::placeholder {
    color: var(--gray-400);
  }
  .dir-empty {
    text-align: center;
    padding: 48px 20px;
    color: var(--gray-400);
    font-size: 15px;
  }

  /* ========== Rank Grid ========== */
  .rank-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .rank-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--gray-200);
    transition: box-shadow 0.25s;
  }
  .rank-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  /* Card header */
  .rank-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 2px solid var(--card-color);
    transition: background 0.15s;
  }
  .rank-header:hover {
    background: var(--gray-100);
  }
  .rank-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--card-color);
    color: #fff;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .rank-header-text {
    flex: 1;
    min-width: 0;
  }
  .rank-header h3 {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 700;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .rank-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    background: var(--gray-100);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--gray-400);
    line-height: 1;
  }
  .rank-desc {
    font-size: 12px;
    color: var(--gray-400);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* List */
  .rank-list {
    padding: 4px 0;
  }
  .rank-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.12s;
  }
  .rank-item:hover {
    background: var(--gray-100);
  }
  .rank-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--gray-400);
    background: var(--gray-100);
    flex-shrink: 0;
    line-height: 1;
  }
  .rank-num.top {
    background: var(--card-color);
    color: #fff;
  }
  .rank-item-title {
    flex: 1;
    font-size: 14px;
    font-weight: 450;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rank-item-tag {
    font-size: 11px;
    color: var(--gray-400);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Expand button */
  .rank-expand {
    display: block;
    width: 100%;
    padding: 10px;
    background: none;
    border: none;
    border-top: 1px solid var(--gray-200);
    font-size: 13px;
    font-weight: 500;
    color: var(--card-color);
    cursor: pointer;
    font-family: var(--sans);
    transition: background 0.15s;
  }
  .rank-expand:hover {
    background: var(--gray-100);
  }

  /* ========== Responsive ========== */
  @media (max-width: 960px) {
    .rank-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .dir-section {
      padding: 20px 16px 48px;
    }
    .dir-top {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }
    .dir-search {
      width: 100%;
    }
    .rank-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .hero-inner {
      padding: 32px 20px 28px;
    }
    .hero-inner h1 {
      font-size: 26px;
    }
    .hero-tagline {
      font-size: 14px;
    }
    .hero-row {
      flex-direction: column;
      gap: 12px;
    }
    .hero-divider {
      display: none;
    }
    .btn-hero {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
    .rank-item-tag {
      display: none;
    }
    .rank-desc {
      display: none;
    }
  }
</style>
