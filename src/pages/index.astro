---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import '../styles/terminal.css';
import { getCollection } from 'astro:content';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const sortedLessons = allLessons.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentLessons = sortedLessons.slice(0, 8);
const totalCount = allLessons.length;

const moduleCounts: Record<string, number> = {};
allLessons.forEach(l => {
  moduleCounts[l.data.module] = (moduleCounts[l.data.module] || 0) + 1;
});

function lessonUrl(slug: string): string {
  const parts = slug.split('/');
  const modulePrefix = parts[0].split('-')[0];
  return `/${modulePrefix}/${parts[1]}`;
}

const moduleNames: Record<string, string> = {
  'm1-basics': '入门篇',
  'm2-thinking': '思维篇',
  'm3-practice': '实战篇',
  'm4-advanced': '进阶篇',
  'm5-compare': '工具对比',
  'm6-sidebiz': '副业指南',
};

---

<BaseLayout
  title="Claude Code 精通之路 — AI 编程实战教程"
  description="最全面的 Claude Code 中文教程站。从入门到实战，工具对比到副业变现，帮你真正掌握 AI 编程。"
>

<!-- Hero -->
<section class="hero">
  <div>
    <div class="hero-meta-row">
      <div class="hero-badge">持续更新 · {totalCount} 篇原创教程</div>
      <a class="hero-update-link" href="/m4/02-claude-code-source-walkthrough">
        <span class="hero-update-new">NEW</span>
        <span class="hero-update-label">最近更新</span>
        <span class="hero-update-title">Claude Code 源码拆解手册</span>
        <span class="hero-update-date">04-06</span>
      </a>
    </div>
    <h1>用 <span class="hl">Claude Code</span><br>做真实项目的实战记录</h1>
    <p class="hero-desc">从安装配置到项目实战，从工具选型到副业变现。不讲花哨技巧，只写工程实践中真正有用的东西。</p>
    <div class="hero-actions">
      <a class="btn-primary" href="/m1">从零开始学</a>
      <a class="btn-secondary" href="/m3">直接看实战</a>
    </div>
  </div>
  <Terminal>
    <div><span class="t-comment"># 真实场景：重构一个认证模块</span></div>
    <div><span class="t-green">$ </span><span class="t-blue">claude</span> <span class="t-orange">"重构 auth 模块，</span></div>
    <div><span class="t-orange">&nbsp;&nbsp;拆分为 login / register / token</span></div>
    <div><span class="t-orange">&nbsp;&nbsp;三个独立服务，保持现有接口不变"</span></div><br>
    <div><span class="t-purple">-- 分析现有代码结构</span></div>
    <div><span class="t-purple">-- 识别 12 个内部依赖</span></div>
    <div><span class="t-purple">-- 生成重构方案</span></div>
    <div><span class="t-purple">-- 拆分为 3 个服务模块</span></div>
    <div><span class="t-purple">-- 同步更新 8 个测试用例</span></div><br>
    <div><span class="t-comment"># prompt 写得再花哨也没用</span></div>
    <div><span class="t-comment"># 关键是你自己先把需求想清楚</span></div><br>
    <div><span class="t-green">$ </span><span class="cursor-blink"></span></div>
  </Terminal>
</section>

<!-- Learning Path -->
<section class="section fade-in">
  <div class="section-label">学习路径</div>
  <h2 class="section-title">六步掌握 AI 编程</h2>
  <p class="section-desc">按顺序学效果最好，也可以按需跳读。每个板块独立成篇。</p>
  <div class="path-grid">

    <a class="path-card" href="/m1" style="--c: #2d8a56">
      <div class="path-step">STEP 01</div>
      <div class="path-label">新手必读</div>
      <h3>入门篇</h3>
      <p>安装配置、核心命令、Prompt 写法、MCP 入门——从零开始，零基础也能跟上。</p>
      <div class="path-foot">
        <span>{moduleCounts['m1-basics'] || 0} 篇</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a class="path-card" href="/m2" style="--c: #c44b2b">
      <div class="path-step">STEP 02</div>
      <div class="path-label">思维建立</div>
      <h3>思维篇</h3>
      <p>任务拆解、上下文管理、代码审查、架构决策——建立与 AI 协作的工程思维。</p>
      <div class="path-foot">
        <span>{moduleCounts['m2-thinking'] || 0} 篇</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a class="path-card" href="/m3" style="--c: #2b6cc4">
      <div class="path-step">STEP 03</div>
      <div class="path-label">动手实战</div>
      <h3>实战篇</h3>
      <p>从零搭建项目、重构复盘、线上排查、CI/CD 自动化——每篇都是完整的真实案例。</p>
      <div class="path-foot">
        <span>{moduleCounts['m3-practice'] || 0} 篇</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a class="path-card" href="/m4" style="--c: #8b5cf6">
      <div class="path-step">STEP 04</div>
      <div class="path-label">深度集成</div>
      <h3>进阶篇</h3>
      <p>Headless 模式、管道操作、Git Hook 集成——把 Claude Code 真正接入工程体系。</p>
      <div class="path-foot">
        <span>{moduleCounts['m4-advanced'] || 0} 篇</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a class="path-card" href="/m5" style="--c: #d97706">
      <div class="path-step">STEP 05</div>
      <div class="path-label">选型参考</div>
      <h3>工具对比</h3>
      <p>Claude Code vs Cursor vs Copilot，模型选型、API vs 订阅——帮你做出最优选择。</p>
      <div class="path-foot">
        <span>{moduleCounts['m5-compare'] || 0} 篇</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a class="path-card" href="/m6" style="--c: #059669">
      <div class="path-step">STEP 06</div>
      <div class="path-label">技术变现</div>
      <h3>副业指南</h3>
      <p>搭建副业网站、AdSense 变现、AI 接单提效——用 AI 开启技术变现之路。</p>
      <div class="path-foot">
        <span>{moduleCounts['m6-sidebiz'] || 0} 篇</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

  </div>
</section>

<!-- Why This Site -->
<section class="philosophy-bg">
  <div class="section fade-in">
    <div class="section-label" style="color: var(--accent-light)">写作初衷</div>
    <h2 class="section-title" style="color: var(--paper)">为什么要写这些</h2>
    <p class="section-desc" style="color: var(--gray-400); margin-bottom: 48px;">用了半年 Claude Code，踩了不少坑，也摸索出一些真正管用的方法。写下来，一方面给自己做备忘，一方面希望对你也有帮助。</p>
    <div class="phil-grid">
      <div class="phil-card">
        <div class="phil-num">01</div>
        <h3>工具只是放大器</h3>
        <p>如果你不会拆解问题，prompt 写得再漂亮也没用。Claude Code 放大的是你的工程能力，不是取代它。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">02</div>
        <h3>命令行才是主场</h3>
        <p>桌面版适合快速提问，但真正做项目还得靠 CLI。它能和 git、docker、CI/CD 串起来，这才是工程化的用法。</p>
      </div>
      <div class="phil-card">
        <div class="phil-num">03</div>
        <h3>踩过的坑最值钱</h3>
        <p>每篇教程里都有我实际遇到的问题和解决过程。比起教你"正确做法"，我更想让你看到"我是怎么一步步试出来的"。</p>
      </div>
    </div>
  </div>
</section>

<!-- Recent Articles -->
<section class="section fade-in">
  <div class="section-label">最近更新</div>
  <h2 class="section-title">最新发布的文章</h2>
  <p class="section-desc">按发布时间倒序排列，点击标题直接阅读。</p>
  <div class="article-list">
    {recentLessons.map((lesson, i) => (
      <a class="article-item" href={lessonUrl(lesson.id)}>
        <span class="a-num">{String(i + 1).padStart(2, '0')}</span>
        <div class="a-info">
          <h4>{lesson.data.title}</h4>
          <p>{moduleNames[lesson.data.module]} / {lesson.data.duration}</p>
        </div>
        <span class="a-arrow">&rarr;</span>
      </a>
    ))}
  </div>
</section>


<!-- CTA -->
<section class="cta-section fade-in">
  <h2>从第一篇开始读</h2>
  <p>不需要任何 AI 编程经验。从安装 Claude Code 开始，一步步带你搭建自己的 AI 编程工作流。所有内容免费，随时可以开始。</p>
  <a class="btn-primary" style="font-size: 16px; padding: 16px 36px;" href="/m1">阅读入门篇</a>
</section>

</BaseLayout>

<style>
  .path-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .path-card {
    position: relative;
    background: var(--paper);
    border: 1.5px solid var(--gray-200);
    border-left: 3px solid var(--c);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all .2s;
  }
  .path-card:hover {
    border-color: var(--c);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,.07);
  }
  .path-step {
    font-size: 11px;
    font-weight: 700;
    font-family: var(--mono);
    color: var(--c);
    letter-spacing: 1px;
  }
  .path-label {
    font-size: 11px;
    color: var(--gray);
    font-weight: 500;
  }
  .path-card h3 {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  .path-card p {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.7;
    flex: 1;
  }
  .path-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
    font-size: 13px;
    color: var(--gray);
  }
  .path-arrow {
    color: var(--c);
    font-size: 16px;
    transition: transform .2s;
  }
  .path-card:hover .path-arrow {
    transform: translateX(4px);
  }

  .hero-meta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: nowrap;
    margin-bottom: 14px;
  }
  .hero-meta-row .hero-badge {
    margin-bottom: 0;
    min-height: 44px;
    padding: 0 16px;
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .hero-update-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #9a3412;
    text-decoration: none;
    min-height: 44px;
    padding: 0 12px;
    border: 1px solid #f3c2ad;
    border-radius: 999px;
    background: #fff3ec;
    max-width: 100%;
    box-shadow: 0 1px 0 rgba(196, 75, 43, 0.08);
  }
  .hero-update-link:hover {
    color: #9a3412;
    border-color: #efb19a;
    background: #ffece3;
  }
  .hero-update-new {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #fff;
    background: #c44b2b;
    border-radius: 999px;
    padding: 2px 6px;
    line-height: 1.4;
  }
  .hero-update-label {
    color: #c44b2b;
    white-space: nowrap;
    font-weight: 600;
  }
  .hero-update-title {
    color: #9a3412;
    font-weight: 700;
    white-space: nowrap;
  }
  .hero-update-date {
    color: #c44b2b;
    font-family: var(--mono);
    font-size: 11px;
    white-space: nowrap;
  }


  @media (max-width: 768px) {
    .path-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .platform-row {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .hero-meta-row { margin-bottom: 10px; gap: 8px; flex-wrap: wrap; }
    .hero-update-link {
      font-size: 11px;
      padding: 6px 8px;
      gap: 6px;
      width: 100%;
      justify-content: flex-start;
    }
    .hero-update-new { font-size: 9px; padding: 1px 5px; }
    .hero-update-title {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }
</style>
